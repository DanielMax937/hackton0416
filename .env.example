# 复制为 .env 或 .env.local 后填写（勿把真实 Key 提交到 Git）
#
# 推荐（与代码默认一致）：
ARK_API_KEY=
ARK_MODEL=
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
#
# 可选别名（与 OpenAI 生态工具一致时）：
# OPENAI_API_KEY=
# OPENAI_MODEL=
#
# 心境地图页引导视频（可选，不填则使用内置示例短片 URL）
# NEXT_PUBLIC_MOOD_MAP_VIDEO_URL=https://example.com/your-intro.mp4
NEXT_PUBLIC_MOOD_MAP_VIDEO_URL=https://www.bitstripe.cn/files/abc.mp4